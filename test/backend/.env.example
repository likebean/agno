# Optional: override default SQLite path (test/backend/tmp/agent_platform.db)
# SQLITE_DB_FILE=tmp/agent_platform.db

# Shared Postgres for knowledge contents + pgvector vectors
# Local docker (agent-platform-postgres):
PGVECTOR_URL=postgresql+psycopg://ai:ai@localhost:5432/ai
# Agno cookbook default (port 5532):
# PGVECTOR_URL=postgresql+psycopg://ai:ai@localhost:5532/ai
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1024

AI_MODEL_NAME=qwen3-30b-a3b-instruct-2507
AI_MODEL_IDS=qwen3-30b-a3b-instruct-2507,qwen-plus,qwen-turbo,qwen-max
AI_MODEL_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL_API_KEY=your_api_key_here
